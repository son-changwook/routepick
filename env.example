# RoutePick API 환경변수 설정 예시
# 이 파일을 복사하여 .env 파일을 만들고 실제 값으로 설정하세요

# =============================================================================
# JWT 설정 (보안 필수)
# =============================================================================
# 프로덕션 환경에서는 반드시 강력한 JWT_SECRET을 설정해야 합니다
# 최소 32자 이상, 영문/숫자/특수문자 포함
JWT_SECRET=your-super-secure-jwt-secret-key-here-minimum-32-characters-with-special-chars

# JWT 토큰 만료 시간 (밀리초)
JWT_EXPIRATION=3600000          # 액세스 토큰: 1시간
JWT_REFRESH_EXPIRATION=2592000000  # 리프레시 토큰: 30일

# JWT 발급자
JWT_ISSUER=routepick-api

# =============================================================================
# 데이터베이스 설정
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=routepick
DB_USERNAME=routepick
DB_PASSWORD=your-secure-database-password

# =============================================================================
# 이메일 설정
# =============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=routepick@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@routepick.com

# =============================================================================
# CORS 설정
# =============================================================================
# 허용할 도메인들을 쉼표로 구분하여 설정
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://routepick.com

# =============================================================================
# 애플리케이션 설정
# =============================================================================
# 프로파일 설정 (dev, prod, production)
SPRING_PROFILES_ACTIVE=dev

# 서버 포트 (선택사항)
SERVER_PORT=8080

# =============================================================================
# 로깅 설정
# =============================================================================
# 로그 레벨 (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ROUTEPICK=DEBUG

# =============================================================================
# 보안 설정
# =============================================================================
# Rate Limiting 설정
RATE_LIMIT_IP_MAX_REQUESTS=100
RATE_LIMIT_IP_WINDOW_SECONDS=60
RATE_LIMIT_EMAIL_MAX_REQUESTS=10
RATE_LIMIT_EMAIL_WINDOW_SECONDS=3600

# =============================================================================
# 파일 업로드 설정
# =============================================================================
# 최대 파일 크기 (바이트)
MAX_FILE_SIZE=5242880  # 5MB

# 허용된 파일 확장자
ALLOWED_FILE_EXTENSIONS=.jpg,.jpeg,.png,.gif 