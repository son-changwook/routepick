# RoutePick API 환경변수 설정 예시
# 이 파일을 복사하여 .env 파일을 만들고 실제 값으로 설정하세요

# =============================================================================
# JWT 보안 설정 (프로덕션 환경 필수)
# =============================================================================
# 강력한 JWT 시크릿 키 (최소 32바이트)
JWT_SECRET=Wgk4m2KYZ/lY55oDW4ky4nQM2bkZwqR1yhI8mTH3r5g4o3/LQfifkQHNALXhexGyjQzsOtjYiT06tLhKGDvtXQ==

# JWT 토큰 만료 시간 (밀리초)
JWT_EXPIRATION=1800000  # 30분
JWT_REFRESH_EXPIRATION=604800000  # 7일

# JWT 발급자
JWT_ISSUER=routepick-api

# JWT 알고리즘 (HS512 권장)
JWT_ALGORITHM=HS512

# JWT 클록 스큐 허용 시간 (초)
JWT_CLOCK_SKEW=30

# =============================================================================
# 데이터베이스 설정
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=routepick
DB_USERNAME=routepick
DB_PASSWORD=your-secure-database-password

# =============================================================================
# 이메일 설정
# =============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=routepick@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@routepick.com

# =============================================================================
# CORS 설정
# =============================================================================
# 허용할 도메인들을 쉼표로 구분하여 설정
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://routepick.com

# =============================================================================
# 애플리케이션 설정
# =============================================================================
# 프로파일 설정 (dev, prod, production)
SPRING_PROFILES_ACTIVE=dev

# 서버 포트 (선택사항)
SERVER_PORT=8080

# =============================================================================
# 로깅 설정
# =============================================================================
# 로그 레벨 (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ROUTEPICK=DEBUG

# =============================================================================
# 보안 설정
# =============================================================================
# Rate Limiting 설정
RATE_LIMIT_IP_MAX_REQUESTS=100
RATE_LIMIT_IP_WINDOW_SECONDS=60
RATE_LIMIT_EMAIL_MAX_REQUESTS=10
RATE_LIMIT_EMAIL_WINDOW_SECONDS=3600

# =============================================================================
# 파일 업로드 설정
# =============================================================================
# 최대 파일 크기 (바이트)
MAX_FILE_SIZE=5242880  # 5MB

# 허용된 파일 확장자
ALLOWED_FILE_EXTENSIONS=.jpg,.jpeg,.png,.gif

# =============================================================================
# Redis 설정
# =============================================================================
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=routepick-redis-password
SPRING_REDIS_TIMEOUT=2000ms
SPRING_REDIS_LETTUCE_POOL_MAX_ACTIVE=8
SPRING_REDIS_LETTUCE_POOL_MAX_IDLE=8
SPRING_REDIS_LETTUCE_POOL_MIN_IDLE=0

# =============================================================================
# 데이터베이스 설정 (추가)
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=routepick
DB_USERNAME=routepick
DB_PASSWORD=routepick 