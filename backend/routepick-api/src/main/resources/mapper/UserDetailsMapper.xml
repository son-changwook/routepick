<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.routepick.api.mapper.UserDetailsMapper">

    <resultMap id="UserDetailsResultMap" type="com.routepick.common.domain.user.UserDetails">
        <id property="detailId" column="detail_id"/>
        <result property="userId" column="user_id"/>
        <result property="nickName" column="nick_name"/>
        <result property="gender" column="gender"/>
        <result property="height" column="height"/>
        <result property="weight" column="weight"/>
        <result property="wingspan" column="wingspan"/>
        <result property="pullReach" column="pull_reach"/>
        <result property="levelId" column="level_id"/>
        <result property="branchId" column="branch_id"/>
        <result property="followingCount" column="following_count"/>
        <result property="followerCount" column="follower_count"/>
        <result property="statusMessage" column="status_message"/>
        <result property="bio" column="bio"/>
        <result property="preferences" column="preferences"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 사용자 ID로 상세 정보 조회 -->
    <select id="findByUserId" resultMap="UserDetailsResultMap">
        <![CDATA[
        SELECT * FROM user_details 
        WHERE user_id = #{userId}
        ]]>
    </select>

    <!-- 닉네임으로 사용자 상세 정보 조회 -->
    <select id="findByNickName" resultMap="UserDetailsResultMap">
        <![CDATA[
        SELECT * FROM user_details 
        WHERE nick_name = #{nickName}
        ]]>
    </select>

    <!-- 닉네임 중복 확인 -->
    <select id="existsByNickName" resultType="boolean">
        <![CDATA[
        SELECT COUNT(*) > 0 FROM user_details 
        WHERE nick_name = #{nickName}
        ]]>
    </select>

    <!-- 사용자 ID로 닉네임 조회 -->
    <select id="findNickNameByUserId" resultType="string">
        <![CDATA[
        SELECT nick_name FROM user_details 
        WHERE user_id = #{userId}
        ]]>
    </select>

    <!-- 사용자 상세 정보 저장 -->
    <insert id="insertUserDetails" parameterType="com.routepick.common.domain.user.UserDetails" useGeneratedKeys="true" keyProperty="detailId">
        <![CDATA[
        INSERT INTO user_details (
            user_id, nick_name, gender, height, weight, wingspan, pull_reach,
            level_id, branch_id, following_count, follower_count,
            status_message, bio, preferences, created_at, updated_at
        ) VALUES (
            #{userId}, #{nickName}, #{gender}, #{height}, #{weight}, #{wingspan}, #{pullReach},
            #{levelId}, #{branchId}, #{followingCount}, #{followerCount},
            #{statusMessage}, #{bio}, #{preferences}, NOW(), NOW()
        )
        ]]>
    </insert>

    <!-- 사용자 상세 정보 수정 -->
    <update id="updateUserDetails" parameterType="com.routepick.common.domain.user.UserDetails">
        <![CDATA[
        UPDATE user_details SET
            nick_name = #{nickName},
            gender = #{gender},
            height = #{height},
            weight = #{weight},
            wingspan = #{wingspan},
            pull_reach = #{pullReach},
            level_id = #{levelId},
            branch_id = #{branchId},
            status_message = #{statusMessage},
            bio = #{bio},
            preferences = #{preferences},
            updated_at = NOW()
        WHERE user_id = #{userId}
        ]]>
    </update>

    <!-- 사용자 상세 정보 삭제 -->
    <delete id="deleteUserDetails">
        <![CDATA[
        DELETE FROM user_details 
        WHERE user_id = #{userId}
        ]]>
    </delete>

</mapper> 